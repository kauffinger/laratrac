{
    "name": "kauffinger/laratrac",
    "description": "Help agents understand your Laravel app",
    "keywords": [
        "Konstantin Auffinger",
        "laravel",
        "laratrac"
    ],
    "homepage": "https://github.com/kauffinger/laratrac",
    "license": "MIT",
    "authors": [
        {
            "name": "Konstantin Auffinger",
            "email": "62616071+kauffinger@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Laratrac\\Laratrac\\": "src/",
            "Laratrac\\Laratrac\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laratrac\\Laratrac\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laratrac\\Laratrac\\LaratracServiceProvider"
            ],
            "aliases": {
                "Laratrac": "Laratrac\\Laratrac\\Facades\\Laratrac"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}